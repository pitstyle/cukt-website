---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('personal');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={project.data.title} description={project.data.description || `${project.data.title} — Piotr Wyrzykowski`}>
  <article class="project">
    <div class="container content">
      <header class="project-header">
        <a href="/personal" class="back">&larr; PROJECTS</a>
        <h1>{project.data.title}</h1>
        {project.data.date && <p class="meta-line">{project.data.date}</p>}
      </header>

      <div class="project-body">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .project { padding: var(--space-xl) 0; }

  .back {
    font-size: 0.8rem;
    color: var(--white-dim);
    display: inline-block;
    margin-bottom: var(--space-lg);
    letter-spacing: 0.1em;
  }
  .back:hover { color: var(--white); }

  .project-header h1 {
    color: var(--red);
    margin-bottom: var(--space-sm);
  }

  .meta-line {
    color: var(--white-dim);
    font-size: 0.9rem;
    margin-bottom: var(--space-xs);
  }

  .project-body {
    margin-top: var(--space-xl);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .project-body :global(h2) {
    color: var(--red);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    font-size: 1.3rem;
  }

  .project-body :global(h3) {
    color: var(--white);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .project-body :global(img) {
    margin: var(--space-lg) 0;
    border: 1px solid var(--border);
  }

  .project-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
    font-size: 0.8rem;
  }

  .project-body :global(th),
  .project-body :global(td) {
    border: 1px solid var(--border);
    padding: var(--space-sm);
    text-align: left;
  }

  .project-body :global(th) {
    background: var(--bg-lighter);
    color: var(--white-dim);
  }
</style>
