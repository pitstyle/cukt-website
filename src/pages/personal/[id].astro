---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('personal');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={`${project.data.title} — Piotr Wyrzykowski`} description={project.data.description || `${project.data.title}${project.data.date ? ` (${project.data.date})` : ''} — art project by Piotr Wyrzykowski (Peter Style).`}>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": project.data.title,
    "url": `https://cukt.click/personal/${project.id}/`,
    "dateCreated": project.data.date || undefined,
    "creator": { "@type": "Person", "name": "Piotr Wyrzykowski", "alternateName": "Peter Style" },
    "description": project.data.description || `${project.data.title} — art project by Piotr Wyrzykowski`,
    "keywords": project.data.tags || []
  })} />

  <section class="page-hero">
    <div class="container">
      <a href="/personal" class="back" data-en="&larr; PROJECTS" data-pl="&larr; PROJEKTY">&larr; PROJECTS</a>
      <h1 class="page-title" id="page-glitch" data-text={project.data.title}>{project.data.title}</h1>
      {project.data.date && <p class="page-sub">{project.data.date}</p>}
    </div>
  </section>

  <article class="project">
    <div class="container content">
      <div class="project-body">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .page-hero {
    padding: 4vw 0 3vw;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .back {
    font-size: 0.8rem;
    color: var(--white-dim);
    display: inline-block;
    margin-bottom: var(--space-lg);
    letter-spacing: 0.1em;
  }
  .back:hover { color: var(--white); }

  .page-title {
    font-size: 6vw;
    font-weight: 800;
    letter-spacing: 0.03em;
    color: var(--red);
    line-height: 0.9;
    position: relative;
    margin-bottom: var(--space-md);
  }

  .page-title::before,
  .page-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .page-title::before {
    color: var(--green);
    animation: pg1 8s infinite;
    clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%);
    opacity: 0;
  }

  .page-title::after {
    color: var(--white);
    animation: pg2 6s infinite 2s;
    clip-path: polygon(0 67%, 100% 67%, 100% 100%, 0 100%);
    opacity: 0;
  }

  @keyframes pg1{0%,95%{opacity:0;transform:translate(0)}96%{opacity:.6;transform:translate(-2px,1px)}97%{opacity:.4;transform:translate(2px,-1px)}98%{opacity:.7;transform:translate(-1px,-1px)}99%,100%{opacity:0;transform:translate(0)}}
  @keyframes pg2{0%,93%{opacity:0;transform:translate(0)}94%{opacity:.5;transform:translate(2px,-2px)}95%{opacity:.3;transform:translate(-2px,1px)}96%{opacity:.6;transform:translate(1px,-1px)}97%,100%{opacity:0;transform:translate(0)}}

  .page-sub {
    font-size: 1.5vw;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--white-dim);
  }

  .project { padding: var(--space-xl) 0; }

  .project-body {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .project-body :global(h1) { display: none; }

  .project-body :global(h2) {
    color: var(--red);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    font-size: 1.3rem;
  }

  .project-body :global(h3) {
    color: var(--white);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .project-body :global(img) {
    margin: var(--space-lg) 0;
    border: 1px solid var(--border);
  }

  .project-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
    font-size: 0.8rem;
  }

  .project-body :global(th),
  .project-body :global(td) {
    border: 1px solid var(--border);
    padding: var(--space-sm);
    text-align: left;
  }

  .project-body :global(th) {
    background: var(--bg-lighter);
    color: var(--white-dim);
  }

  @media (max-width: 768px) {
    .page-title { font-size: 10vw; }
    .page-sub { font-size: 3vw; }
  }
</style>

<script>
  const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
  function scramble(el:Element,text:string,dur=1200){const len=text.length;let f=0;const tot=dur/30;const iv=setInterval(()=>{let r='';for(let i=0;i<len;i++){const p=f/tot,c=i/len;r+=p>c+.3?text[i]:chars[Math.floor(Math.random()*chars.length)];}el.textContent=r;f++;if(f>tot){el.textContent=text;clearInterval(iv);}},30);}
  const t=document.getElementById('page-glitch');
  if(t){const tx=t.textContent||'';setTimeout(()=>scramble(t,tx,1000),200);setInterval(()=>scramble(t,t.getAttribute('data-text')||tx,600),12000+Math.random()*8000);}
  const lang=localStorage.getItem('cuktai-lang')||'en';
  document.querySelectorAll('[data-pl][data-en]').forEach(el=>{const v=el.getAttribute(`data-${lang}`);if(v)el.innerHTML=v;});
</script>
