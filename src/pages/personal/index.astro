---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('personal');
const sorted = projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="Piotr Wyrzykowski — Art Projects" description="Art projects by Piotr Wyrzykowski (Peter Style) — KHODA, Polaka Twarz, MobileArt, Technopera, and more. Performance, video, new media.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title" id="page-glitch" data-text="PROJECTS" data-en="PROJECTS" data-pl="PROJEKTY">PROJECTS</h1>
      <p class="page-sub">PIOTR WYRZYKOWSKI / PETER STYLE</p>
    </div>
  </section>

  <section class="list">
    <div class="container">
      <div class="grid-projects">
        {sorted.map((project, i) => (
          <a href={`/personal/${project.id}`} class="project-card">
            <span class="card-index">{String(i + 1).padStart(2, '0')}</span>
            <h3>{project.data.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding: 6vw 0 4vw;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .page-title {
    font-size: 10vw;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--red);
    line-height: 0.9;
    position: relative;
  }

  .page-title::before,
  .page-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .page-title::before {
    color: var(--green);
    animation: pg1 8s infinite;
    clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%);
    opacity: 0;
  }

  .page-title::after {
    color: var(--white);
    animation: pg2 6s infinite 2s;
    clip-path: polygon(0 67%, 100% 67%, 100% 100%, 0 100%);
    opacity: 0;
  }

  @keyframes pg1 {
    0%,95%{opacity:0;transform:translate(0)}96%{opacity:.6;transform:translate(-2px,1px)}97%{opacity:.4;transform:translate(2px,-1px)}98%{opacity:.7;transform:translate(-1px,-1px)}99%,100%{opacity:0;transform:translate(0)}
  }
  @keyframes pg2 {
    0%,93%{opacity:0;transform:translate(0)}94%{opacity:.5;transform:translate(2px,-2px)}95%{opacity:.3;transform:translate(-2px,1px)}96%{opacity:.6;transform:translate(1px,-1px)}97%,100%{opacity:0;transform:translate(0)}
  }

  .page-sub {
    font-size: 1.5vw;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--white-dim);
    margin-top: var(--space-md);
  }

  .list { padding: var(--space-xl) 0; }

  .card-index {
    font-size: 0.7rem;
    color: var(--red-dim);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .project-card {
    display: block;
    text-decoration: none;
    color: var(--white);
  }

  .project-card h3 {
    color: var(--white);
  }

  .project-card:hover h3 {
    color: var(--red);
  }

  @media (max-width: 768px) {
    .page-title { font-size: 14vw; }
    .page-sub { font-size: 3vw; }
  }
</style>

<script>
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
  function scramble(el: Element, text: string, dur = 1200) {
    const len = text.length; let f = 0; const tot = dur / 30;
    const iv = setInterval(() => {
      let r = ''; for (let i = 0; i < len; i++) { const p = f/tot, c = i/len; r += p > c+.3 ? text[i] : chars[Math.floor(Math.random()*chars.length)]; }
      el.textContent = r; f++; if (f > tot) { el.textContent = text; clearInterval(iv); }
    }, 30);
  }
  const t = document.getElementById('page-glitch');
  if (t) { const tx = t.textContent||''; setTimeout(()=>scramble(t,tx,1000),200); setInterval(()=>scramble(t,t.getAttribute('data-text')||tx,600),12000+Math.random()*8000); }
  const lang = localStorage.getItem('cuktai-lang')||'en';
  document.querySelectorAll('[data-pl][data-en]').forEach(el => { const v = el.getAttribute(`data-${lang}`); if(v){el.textContent=v;if(el.hasAttribute('data-text'))el.setAttribute('data-text',v);} });
</script>
