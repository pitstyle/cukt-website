---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('personal');
const sorted = projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="PROJECTS" description="Piotr Wyrzykowski / Peter Style — art projects">
  <section class="header">
    <div class="container">
      <h1>PIOTR WYRZYKOWSKI<br /><span class="alias">PETER STYLE</span></h1>
      <p class="subtitle">PERFORMANCE / VIDEO / INSTALLATION / INTERACTIVE ART</p>
    </div>
  </section>

  <section class="list">
    <div class="container">
      <div class="grid-projects">
        {sorted.map((project, i) => (
          <a href={`/personal/${project.id}`} class="project-card">
            <span class="card-index">{String(i + 1).padStart(2, '0')}</span>
            <h3>{project.data.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .header {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .header h1 {
    color: var(--red);
    margin-bottom: var(--space-sm);
  }

  .alias {
    color: var(--white-dim);
    font-size: 1.5rem;
  }

  .subtitle {
    color: var(--white-dim);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
  }

  .list {
    padding: var(--space-xl) 0;
  }

  .card-index {
    font-size: 0.7rem;
    color: var(--red-dim);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-xs);
  }
</style>
