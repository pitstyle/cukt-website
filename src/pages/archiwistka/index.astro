---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('archiwistka');
const karty = all.filter(d => d.data.type === 'karta').sort((a, b) => b.data.date.localeCompare(a.data.date));
const teczki = all.filter(d => d.data.type === 'teczka').sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Base title="ARCHIWISTKA" description="Night Investigator — investigation files and project cards from the CUKT archive">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title" id="page-glitch" data-text="ARCHIWISTKA" data-en="ARCHIWISTKA" data-pl="ARCHIWISTKA">ARCHIWISTKA</h1>
      <p class="page-sub" data-en={`${teczki.length} TECZKI / ${karty.length} KARTY`} data-pl={`${teczki.length} TECZKI / ${karty.length} KARTY`}>{teczki.length} TECZKI / {karty.length} KARTY</p>
    </div>
  </section>

  {karty.length > 0 && (
    <section class="archive-list">
      <div class="container">
        <h2 class="section-head" data-en="PROJECT CARDS" data-pl="KARTY PROJEKTÓW">PROJECT CARDS</h2>
        <div class="grid-projects">
          {karty.map((doc, i) => (
            <a href={`/archiwistka/${doc.id}`} class="project-card">
              <span class="card-number">KARTA</span>
              <h3>{doc.data.title}</h3>
              <p class="meta">{doc.data.date}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="archive-list">
    <div class="container">
      <h2 class="section-head" data-en="INVESTIGATION FILES" data-pl="TECZKI ŚLEDCZE">INVESTIGATION FILES</h2>
      <div class="grid-projects">
        {teczki.map((doc, i) => (
          <a href={`/archiwistka/${doc.id}`} class="project-card">
            <span class="card-number">{String(i + 1).padStart(2, '0')}</span>
            <h3>{doc.data.title}</h3>
            <p class="meta">{doc.data.date} — {doc.data.status}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding: 6vw 0 4vw;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .page-title {
    font-size: 10vw;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--red);
    line-height: 0.9;
    position: relative;
  }

  .page-title::before,
  .page-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .page-title::before {
    color: var(--green);
    animation: page-glitch-1 8s infinite;
    clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%);
    opacity: 0;
  }

  .page-title::after {
    color: var(--white);
    animation: page-glitch-2 6s infinite 2s;
    clip-path: polygon(0 67%, 100% 67%, 100% 100%, 0 100%);
    opacity: 0;
  }

  @keyframes page-glitch-1 {
    0%, 95% { opacity: 0; transform: translate(0); }
    96% { opacity: 0.6; transform: translate(-2px, 1px); }
    97% { opacity: 0.4; transform: translate(2px, -1px); }
    98% { opacity: 0.7; transform: translate(-1px, -1px); }
    99%, 100% { opacity: 0; transform: translate(0); }
  }

  @keyframes page-glitch-2 {
    0%, 93% { opacity: 0; transform: translate(0); }
    94% { opacity: 0.5; transform: translate(2px, -2px); }
    95% { opacity: 0.3; transform: translate(-2px, 1px); }
    96% { opacity: 0.6; transform: translate(1px, -1px); }
    97%, 100% { opacity: 0; transform: translate(0); }
  }

  .page-sub {
    font-size: 1.5vw;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--white-dim);
    margin-top: var(--space-md);
  }

  .archive-list {
    padding: var(--space-xl) 0;
  }

  .section-head {
    color: var(--red);
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .card-number {
    color: var(--red-dim);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .project-card h3 {
    color: var(--white);
  }

  @media (max-width: 768px) {
    .page-title { font-size: 14vw; }
    .page-sub { font-size: 3vw; }
  }
</style>

<script>
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';

  function scramble(el: Element, finalText: string, duration = 1200) {
    const len = finalText.length;
    let frame = 0;
    const totalFrames = duration / 30;
    const interval = setInterval(() => {
      let result = '';
      for (let i = 0; i < len; i++) {
        const progress = frame / totalFrames;
        const charProgress = i / len;
        if (progress > charProgress + 0.3) result += finalText[i];
        else result += chars[Math.floor(Math.random() * chars.length)];
      }
      el.textContent = result;
      frame++;
      if (frame > totalFrames) { el.textContent = finalText; clearInterval(interval); }
    }, 30);
  }

  const title = document.getElementById('page-glitch');
  if (title) {
    const text = title.textContent || '';
    setTimeout(() => scramble(title, text, 1000), 200);
    setInterval(() => scramble(title, title.getAttribute('data-text') || text, 600), 12000 + Math.random() * 8000);
  }

  const lang = localStorage.getItem('cuktai-lang') || 'en';
  document.querySelectorAll('[data-pl][data-en]').forEach(el => {
    const text = el.getAttribute(`data-${lang}`);
    if (text) {
      el.textContent = text;
      if (el.hasAttribute('data-text')) el.setAttribute('data-text', text);
    }
  });
</script>
