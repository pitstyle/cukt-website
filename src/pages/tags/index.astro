---
import Base from '../../layouts/Base.astro';
---

<Base title="Tagi" description="Wątki łączące projekty C.U.K.T. i prace osobiste Piotra Wyrzykowskiego">
  <section class="header">
    <div class="container">
      <h1 >Tagi / Wątki</h1>
      <p class="subtitle">Narracja przekrojowa — wątki łączące oba archiwa</p>
    </div>
  </section>

  <section class="tags-grid">
    <div class="container">
      <div class="grid-projects">
        <div class="project-card">
          <h3>#ciało</h3>
          <p class="desc">Testy na Cyborga, There Is No Body, Cyborg's Sex Manual, Manhunt</p>
        </div>
        <div class="project-card">
          <h3>#instytucja</h3>
          <p class="desc">Wiktoria Cukt, Antyelekcja, CUKTAI, Fundacja Bot</p>
        </div>
        <div class="project-card">
          <h3>#technologia</h3>
          <p class="desc">Technopera, N.T.S.C., Lab 6, Mobile Art, CUKTAI</p>
        </div>
        <div class="project-card">
          <h3>#tożsamość</h3>
          <p class="desc">Wiktoria Cukt, Polaka Twarz, Zoriana, Ewa Virus</p>
        </div>
        <div class="project-card">
          <h3>#performance</h3>
          <p class="desc">120h, HERE Performance, Przysięga Prezydenta, Concert for</p>
        </div>
        <div class="project-card">
          <h3>#wideo</h3>
          <p class="desc">Beta Nassau, Atomic Love, KHODA, Video Art</p>
        </div>
      </div>
      <p class="pending"><span class="status-warn">[IN PROGRESS]</span> System tagów w budowie — powiązania między projektami.</p>
    </div>
  </section>
</Base>

<style>
  .header {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .subtitle {
    color: var(--white-dim);
  }

  .tags-grid {
    padding: var(--space-xl) 0;
  }

  .desc {
    font-size: 0.85rem;
    color: var(--white-dim);
    font-family: var(--font-mono);
  }

  .pending {
    margin-top: var(--space-xl);
    font-size: 0.9rem;
    color: var(--white-dim);
  }
</style>
