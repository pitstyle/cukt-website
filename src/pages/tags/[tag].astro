---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allTags = ['body', 'institution', 'technology', 'identity', 'performance', 'video'];

  const cukt = await getCollection('cukt');
  const personal = await getCollection('personal');

  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      cuktProjects: cukt.filter(p => p.data.tags?.includes(tag)),
      personalProjects: personal.filter(p => p.data.tags?.includes(tag)),
    },
  }));
}

const { tag, cuktProjects, personalProjects } = Astro.props;
const tagUpper = tag.toUpperCase();
const total = cuktProjects.length + personalProjects.length;
---

<Base title={`#${tagUpper}`} description={`Projects tagged #${tag} — CUKTAI cross-archive narrative`}>
  <section class="page-hero">
    <div class="container">
      <a href="/tags" class="back">&larr; TAGS</a>
      <h1 class="page-title" id="page-glitch" data-text={`#${tagUpper}`}>#{tagUpper}</h1>
      <p class="page-sub">{total} PROJECTS ACROSS BOTH ARCHIVES</p>
    </div>
  </section>

  {cuktProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <h2>CUKT ARCHIVE</h2>
        <div class="grid-projects">
          {cuktProjects.map((p, i) => (
            <a href={`/archive/${p.id}`} class="project-card">
              <span class="card-number">{String(i + 1).padStart(2, '0')}</span>
              <h3>{p.data.title}</h3>
              <p class="meta">{p.data.date}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {personalProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <h2>PERSONAL PROJECTS</h2>
        <div class="grid-projects">
          {personalProjects.map((p, i) => (
            <a href={`/personal/${p.id}`} class="project-card">
              <span class="card-number">{String(i + 1).padStart(2, '0')}</span>
              <h3>{p.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .page-hero {
    padding: 4vw 0 3vw;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .back {
    font-size: 0.8rem;
    color: var(--white-dim);
    display: inline-block;
    margin-bottom: var(--space-lg);
    letter-spacing: 0.1em;
  }
  .back:hover { color: var(--white); }

  .page-title {
    font-size: 10vw;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--red);
    line-height: 0.9;
    position: relative;
  }

  .page-title::before,
  .page-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .page-title::before {
    color: var(--green);
    animation: pg1 8s infinite;
    clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%);
    opacity: 0;
  }

  .page-title::after {
    color: var(--white);
    animation: pg2 6s infinite 2s;
    clip-path: polygon(0 67%, 100% 67%, 100% 100%, 0 100%);
    opacity: 0;
  }

  @keyframes pg1{0%,95%{opacity:0;transform:translate(0)}96%{opacity:.6;transform:translate(-2px,1px)}97%{opacity:.4;transform:translate(2px,-1px)}98%{opacity:.7;transform:translate(-1px,-1px)}99%,100%{opacity:0;transform:translate(0)}}
  @keyframes pg2{0%,93%{opacity:0;transform:translate(0)}94%{opacity:.5;transform:translate(2px,-2px)}95%{opacity:.3;transform:translate(-2px,1px)}96%{opacity:.6;transform:translate(1px,-1px)}97%,100%{opacity:0;transform:translate(0)}}

  .page-sub {
    font-size: 1.5vw;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--white-dim);
    margin-top: var(--space-md);
  }

  .section {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--border);
  }

  .section h2 {
    color: var(--red);
    font-size: 1rem;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-lg);
  }

  .card-number {
    font-size: 0.7rem;
    color: var(--red-dim);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .project-card {
    display: block;
    text-decoration: none;
    color: var(--white);
  }

  .project-card h3 {
    color: var(--white) !important;
  }

  .project-card:hover h3 {
    color: var(--red) !important;
  }

  @media (max-width: 768px) {
    .page-title { font-size: 14vw; }
    .page-sub { font-size: 3vw; }
  }
</style>

<script>
  const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
  function scramble(el:Element,text:string,dur=1200){const len=text.length;let f=0;const tot=dur/30;const iv=setInterval(()=>{let r='';for(let i=0;i<len;i++){const p=f/tot,c=i/len;r+=p>c+.3?text[i]:chars[Math.floor(Math.random()*chars.length)];}el.textContent=r;f++;if(f>tot){el.textContent=text;clearInterval(iv);}},30);}
  const t=document.getElementById('page-glitch');
  if(t){const tx=t.textContent||'';setTimeout(()=>scramble(t,tx,1000),200);setInterval(()=>scramble(t,t.getAttribute('data-text')||tx,600),12000+Math.random()*8000);}
</script>
