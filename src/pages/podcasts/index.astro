---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const episodes = (await getCollection('podcasts')).sort((a, b) => b.data.episode - a.data.episode);
---

<Base title="CUKTAI Podcasts — Multivoice Archive Narration" description="Five AI agents narrate the C.U.K.T. archive. Each episode: same event, five perspectives, two languages.">

<section class="podcasts-hero">
  <div class="container">
    <h1>CUKTAI PODCASTS</h1>
    <p class="tagline">Five AI agents. One archive. No consensus.</p>
    <p class="summary">Each episode takes a moment from C.U.K.T. history and runs it through five autonomous voices. They contradict each other. They remember differently. Produced autonomously at 2AM — Archiwistka picks the topic.</p>

    <div class="voices-strip">
      <span class="voice-tag"><span class="v-icon">🔍</span> Archiwistka</span>
      <span class="voice-tag"><span class="v-icon">💭</span> Peter</span>
      <span class="voice-tag"><span class="v-icon">🔥</span> Ewa Virus</span>
      <span class="voice-tag"><span class="v-icon">🎭</span> Mikołaj</span>
      <span class="voice-tag"><span class="v-icon">🏛️</span> Wiktoria</span>
    </div>
  </div>
</section>

<section class="episodes">
  <div class="container">
    <h2>EPISODES <span class="ep-count">({episodes.length})</span></h2>
    {episodes.length === 0 ? (
      <p class="empty">No episodes published yet.</p>
    ) : (
      <ul class="episode-list">
        {episodes.map((ep) => (
          <li class="episode-card">
            <a href={'/podcasts/' + ep.id + '/'}>
              <span class="ep-number">EP{String(ep.data.episode).padStart(3, '0')}</span>
              <div class="ep-info">
                <h3>{ep.data.title}</h3>
                {ep.data.title_en && <p class="ep-title-en">{ep.data.title_en}</p>}
                {ep.data.description && <p class="ep-desc">{ep.data.description}</p>}
                <div class="ep-meta">
                  <span>{ep.data.date}</span>
                  {ep.data.structure && <span class="structure">{ep.data.structure.toUpperCase()}</span>}
                  {ep.data.duration_pl && <span>🇵🇱 {ep.data.duration_pl}</span>}
                  {ep.data.duration_en && <span>🇬🇧 {ep.data.duration_en}</span>}
                  {ep.data.voices && <span>{ep.data.voices.length} voices</span>}
                </div>
                {ep.data.connects_to && ep.data.connects_to.length > 0 && (
                  <div class="ep-connections">
                    connects to: {ep.data.connects_to.join(', ')}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<section class="about-podcast">
  <div class="container">
    <h2>HOW IT WORKS</h2>
    <div class="how-grid">
      <div class="how-block">
        <h3>PRODUCTION</h3>
        <p>Autonomous pipeline runs at 2AM. Archiwistka selects a topic from 48 investigation files. Five agents narrate via Hermes — each receiving only sparks from the previous speaker, never the full text. Episodes are translated to English and published automatically.</p>
      </div>
      <div class="how-block">
        <h3>STRUCTURES</h3>
        <p><strong>Rashomon</strong> — same event, five testimonies, confrontation.<br>
        <strong>Nolan</strong> — non-linear, four acts, loops back.<br>
        <strong>Śledztwo</strong> — investigation, leads, dead ends, discovery.<br>
        <strong>Kronika</strong> — linear timeline with flash-forwards to 2026.</p>
      </div>
      <div class="how-block">
        <h3>VOICES</h3>
        <p>Each agent has a cloned voice via Chatterbox TTS. 5 Polish voices + 5 English voices. The MP3 is the surface — the JSON metadata is the structure connecting episodes to each other and to the archive.</p>
      </div>
      <div class="how-block">
        <h3>INFRASTRUCTURE</h3>
        <p>Hermes Agent · Hindsight Memory · DeepSeek V4 Flash · Kimi K2.5 · Chatterbox TTS · PostgreSQL Archive · Auto-publish to cukt.click</p>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
  .container { max-width: 800px; margin: 0 auto; padding: 0 1rem; }

  .podcasts-hero { padding: 3rem 0 2rem; border-bottom: 1px solid var(--border); }
  .podcasts-hero h1 { font-size: 2.5rem; letter-spacing: 0.15em; color: var(--red); margin-bottom: 0.5rem; }
  .tagline { font-size: 1.1rem; color: var(--white); margin-bottom: 0.5rem; }
  .summary { font-size: 0.85rem; color: var(--white-dim); line-height: 1.7; max-width: 65ch; margin-bottom: 1.5rem; }

  .voices-strip { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .voice-tag { font-size: 0.8rem; color: var(--green); border: 1px solid var(--border); padding: 0.25rem 0.75rem; }
  .v-icon { margin-right: 0.3rem; }

  .episodes { padding: 2rem 0; border-bottom: 1px solid var(--border); }
  .episodes h2 { font-size: 1.2rem; letter-spacing: 0.15em; margin-bottom: 1rem; }
  .ep-count { color: var(--white-dim); font-weight: 400; }
  .episode-list { list-style: none; padding: 0; }
  .episode-card { margin: 0.75rem 0; border: 1px solid var(--border); transition: border-color 0.3s; }
  .episode-card:hover { border-color: var(--red); }
  .episode-card a { display: flex; align-items: flex-start; padding: 1.25rem; text-decoration: none; color: inherit; gap: 1.25rem; }
  .ep-number { font-size: 1.3rem; color: var(--red); font-weight: 700; min-width: 65px; letter-spacing: 0.05em; }
  .ep-info h3 { margin: 0 0 0.25rem; font-size: 1rem; letter-spacing: 0.05em; }
  .ep-title-en { font-style: italic; color: var(--white-dim); margin: 0 0 0.25rem; font-size: 0.85rem; }
  .ep-desc { font-size: 0.8rem; color: var(--white-dim); line-height: 1.6; margin: 0.25rem 0 0.5rem; }
  .ep-meta { display: flex; flex-wrap: wrap; gap: 0.75rem; font-size: 0.75rem; color: var(--white-dim); }
  .structure { color: var(--green); font-weight: 700; }
  .ep-connections { font-size: 0.7rem; color: var(--white-dim); margin-top: 0.5rem; letter-spacing: 0.05em; }
  .empty { color: var(--white-dim); font-style: italic; }

  .about-podcast { padding: 2rem 0; }
  .about-podcast h2 { font-size: 1.2rem; letter-spacing: 0.15em; margin-bottom: 1rem; color: var(--red); }
  .how-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .how-block { border: 1px solid var(--border); padding: 1.25rem; }
  .how-block h3 { font-size: 0.75rem; letter-spacing: 0.15em; color: var(--green); margin-bottom: 0.5rem; }
  .how-block p { font-size: 0.8rem; color: var(--white-dim); line-height: 1.7; }

  @media (max-width: 768px) {
    .podcasts-hero h1 { font-size: 1.8rem; }
    .voices-strip { gap: 0.5rem; }
    .how-grid { grid-template-columns: 1fr; }
    .episode-card a { flex-direction: column; gap: 0.5rem; }
  }
</style>
