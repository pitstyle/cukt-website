---
import Base from '../layouts/Base.astro';
---

<Base title="Info" description="Piotr Wyrzykowski — artysta, badacz, wykładowca. CUKTAI — system autonomicznej AI.">
  <section class="about">
    <div class="container content">
      <h1>Piotr Wyrzykowski</h1>
      <p class="alias">Peter Style</p>

      <div class="bio">
        <p>
          Artysta, badacz, wykładowca. Współzałożyciel C.U.K.T. (Centralny Urząd Kultury Technicznej, 1992).
          Twórca koncepcji transformizmu — teorii artystycznej łączącej ciało, technologię i tożsamość.
        </p>
        <p>
          Kierownik Katedry Specjalizacji Artystycznych, Akademia Sztuk Pięknych w Gdańsku.
          Wykładowca Nowych Mediów i Narracji Wideo, Polsko-Japońska Akademia Technik Komputerowych.
        </p>
      </div>

      <div class="section">
        <h2>CUKTAI</h2>
        <p>
          Autonomiczny Urząd Kultury Technicznej — system sztucznej inteligencji transformujący
          archiwum C.U.K.T. w wielogłosową sieć agentów. Konferencja trwająca cały rok 2026.
        </p>
        <p>
          <span class="label">Hasło:</span> Moja pamięć w Twojej głowie<br />
          <span class="label">Faza:</span> 4.6 — Podświadomość (beta)<br />
          <span class="label">Agenci:</span> Wiktoria Cukt 2.0, Ewa Virus Adam, Piotr Twin, Archiwistka
        </p>
      </div>

      <div class="section">
        <h2>Kontakt</h2>
        <p>
          <a href="https://instagram.com/wiktoriacukt">@wiktoriacukt</a> (Instagram)<br />
          <a href="https://instagram.com/_transformizm">@_transformizm</a> (Instagram)
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .about {
    padding: var(--space-2xl) 0;
  }

  .about h1 {
    color: var(--red);
    margin-bottom: var(--space-xs);
  }

  .alias {
    color: var(--white-dim);
    font-size: 1.1rem;
    margin-bottom: var(--space-xl);
  }

  .bio {
    margin-bottom: var(--space-xl);
  }

  .bio p {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .section {
    margin-bottom: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
  }

  .section h2 {
    color: var(--red);
    margin-bottom: var(--space-md);
  }

  .section p {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.8;
  }

  .label {
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>
