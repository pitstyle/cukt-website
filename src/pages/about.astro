---
import Base from '../layouts/Base.astro';
---

<Base title="ABOUT" description="Piotr Wyrzykowski — artist, researcher, lecturer. CUKTAI — autonomous AI system.">
  <section class="about">
    <div class="container content">
      <h1>PIOTR WYRZYKOWSKI</h1>
      <p class="alias">PETER STYLE</p>

      <div class="bio">
        <p>
          Artist, researcher, lecturer. Co-founder of C.U.K.T. (Centralny Urzad Kultury Technicznej, 1995).
          Creator of Transformism — an artistic theory connecting body, technology, and identity.
        </p>
        <p>
          Head of Department of Artistic Specializations, Academy of Fine Arts in Gdansk.
          Lecturer in New Media and Video Narrative, Polish-Japanese Academy of Information Technology.
        </p>
      </div>

      <div class="section">
        <h2>CUKTAI</h2>
        <p>
          Autonomous Bureau of Technical Culture — an AI system transforming
          the C.U.K.T. archive into a multi-voice agent network. Year-long conference, 2026.
        </p>
        <p>
          <span class="label">MOTTO:</span> My memory in your head<br />
          <span class="label">PHASE:</span> 4.6 — Subconsciousness (beta)<br />
          <span class="label">AGENTS:</span> Wiktoria Cukt 2.0, Ewa Virus Adam, Peter Twin, Archiwistka
        </p>
      </div>

      <div class="section">
        <h2 data-en="CONTACT" data-pl="KONTAKT">CONTACT</h2>
        <p>
          <a href="https://instagram.com/wiktoriacukt">@WIKTORIACUKT</a><br />
          <a href="https://instagram.com/_transformizm">@_TRANSFORMIZM</a>
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .about { padding: var(--space-2xl) 0; }

  .about h1 {
    color: var(--red);
    margin-bottom: var(--space-xs);
  }

  .alias {
    color: var(--white-dim);
    font-size: 1.1rem;
    margin-bottom: var(--space-xl);
  }

  .bio { margin-bottom: var(--space-xl); }

  .bio p {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .section {
    margin-bottom: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
  }

  .section h2 {
    color: var(--red);
    margin-bottom: var(--space-md);
  }

  .section p {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .label {
    color: var(--white-dim);
    font-size: 0.8rem;
  }
</style>

<script>
  const lang = localStorage.getItem('cuktai-lang') || 'en';
  document.querySelectorAll('[data-pl][data-en]').forEach(el => {
    const text = el.getAttribute(`data-${lang}`);
    if (text) el.textContent = text;
  });
</script>
