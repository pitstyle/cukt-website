---
import Base from '../layouts/Base.astro';
---

<Base title="About — CUKTAI" description="The people behind CUKTAI — Piotr Wyrzykowski, Adam Popek (Ewa Virus), Robert Mikołaj Jurkowski, Wiktoria Cukt 2.0, Archiwistka.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title" id="page-glitch" data-text="ABOUT" data-en="ABOUT" data-pl="INFO">ABOUT</h1>
      <p class="page-sub">THE PEOPLE AND AGENTS OF CUKTAI</p>
    </div>
  </section>

  <section class="about">
    <div class="container content">

      <!-- PIOTR -->
      <div class="person">
        <h2>PIOTR WYRZYKOWSKI <span class="aka">alias Peter Style</span></h2>
        <p class="role">Co-founder of C.U.K.T. (1995) · Creator of CUKTAI · CUKTAI Agent: Peter Twin</p>
        <div class="bio-text">
          <p>
            Born 1968 in Gdańsk. Artist, performer, production designer. MA at Intermedia Studio of Prof. W. Czerwonka, Academy of Fine Arts in Gdańsk. Co-founder of CSW Łaźnia (former Open Atelier Foundation), vice president of Wyspa Progress Foundation.
          </p>
          <p>
            Co-founder and artistic director of C.U.K.T. — Central Office of Technical Culture (1995–2001). Creator of the Presidential Campaign of Wiktoria Cukt (2000) — a virtual candidate for the President of Poland, interface of the collective decision-making program OSW. Author of the pioneering Polish internet work <em>44</em> (1999).
          </p>
          <p>
            Head of Department of Artistic Specializations, Academy of Fine Arts in Gdańsk. Lecturer in New Media and Video Narrative, Polish-Japanese Academy of Information Technology. Developer of Transformism — an artistic theory connecting body, technology, and identity.
          </p>
          <p>
            Works in collections of MoMA New York (<em>Beta Nassau</em>, 1993), Centre Pompidou Paris (<em>Atomic Love</em>, 2006), Muzeum Sztuki Łódź, NOMUS Gdańsk.
          </p>
          <p class="distinctions">
            Grand Prix Gdańsk Art Biennale (2021) · International Intermedia Art Competition, Kraków (2018) · City of Gdańsk Award (2008) · Visiting Artist: Stanford, Art Institute of Chicago · Deutscher Videokunstpreis ZKM (1994) · WRO Media Festival 1st Prize (1995)
          </p>
        </div>
      </div>

      <!-- EWA / ADAM POPEK -->
      <div class="person">
        <h2>ADAM POPEK <span class="aka">alias Ewa Virus Adam</span></h2>
        <p class="role">Co-founder of C.U.K.T. (1995) · Sound artist · CUKTAI Agent: Ewa Virus</p>
        <div class="bio-text">
          <p>
            Born 1967 in Rzeszów. Studied painting at the Academy of Fine Arts in Gdańsk (1990–1996). Sound artist exploring the sonic possibilities of everyday digital machines — designing sound waves, textures, and structures that inspire human emotions and challenge aesthetic conventions.
          </p>
          <p>
            Co-founder of C.U.K.T. (1995–2000) — a series of technodemonstrations and artistic interventions in public space. Active performer since 1992, starting with Venom Underground at Łaźnia gallery. Permanent concert activity 1995–2025 in formations: UV Crew, Venom Underground, Midi Reisers, and individually as Virus, Aluette, Midi Reiser, Kura from Hell, Ewa, Very Bad Mother.
          </p>
          <p class="distinctions">
            Audio publications: "Danzig Dance Music" (1995), "Technoopera" (1995), "Der Acht Bit Klang Des Waldes" (1998), "Marseille" (2000), "Kapitalism" (2005), "French Lies" (2023), "Symphonique Machine ou Machine Noir" (2025), Ballet "Le Lac Numérique des Cygnes" (2025). Analogue period 2006–2022: "Scheisse for Ever", "Death Floor", "Micosis Tonight", "Legs Up".
          </p>
        </div>
      </div>

      <!-- EWA PL -->
      <div class="person bio-pl">
        <h3>Adam Popek — wersja polska</h3>
        <div class="bio-text">
          <p>
            Urodzony w 1967 roku w Rzeszowie. W latach 1990–1996 studiował malarstwo na Akademii Sztuk Pięknych w Gdańsku. Artysta dźwiękowy eksplorujący możliwości soniczne codziennych maszyn cyfrowych — projektujący fale dźwiękowe, tekstury i struktury inspirujące ludzkie emocje i kwestionujące estetyczne konwenanse.
          </p>
          <p>
            Współzałożyciel C.U.K.T. (1995–2000) — serii technodemonstracji i interwencji artystycznych w przestrzeni publicznej. Aktywny performer od 1992, zaczynając od Venom Underground w galerii Łaźnia. Permanentna aktywność koncertowa 1995–2025 w formacjach: UV Crew, Venom Underground, Midi Reisers, oraz indywidualnie jako Virus, Aluette, Midi Reiser, Kura from Hell, Ewa, Very Bad Mother.
          </p>
          <p>
            Publikacje audio: „Danzig Dance Music" (1995), „Technoopera" (1995), „Der Acht Bit Klang Des Waldes" (1998), „Marseille" (2000), „Kapitalism" (2005), „French Lies" (2023), „Symphonique Machine ou Machine Noir" (2025), balet „Le Lac Numérique des Cygnes" (2025).
          </p>
        </div>
      </div>

      <!-- MIKOŁAJ -->
      <div class="person">
        <h2>ROBERT MIKOŁAJ JURKOWSKI</h2>
        <p class="role">Co-founder of C.U.K.T. (1995) · Artist, educator · CUKTAI Agent: Mikołaj</p>
        <div class="bio-text">
          <p>
            Born 1966. Artist, educator, social activist, cultural animator. In 1987 co-founded the Kościotrup group with Paweł "Paulus" Mazur. Studied art education at Maria Curie-Skłodowska University in Lublin (1988), then transferred to the Faculty of Painting at the State Higher School of Fine Arts in Gdańsk (1992), graduating from the new media studio with the thesis <em>Transgresja jako propozycja w sztuce</em> (Transgression as a proposition in art).
          </p>
          <p>
            In 1994 co-created the precursor project praC.U.K.T. with Piotr Wyrzykowski: <em>120h Mega Techno Obecności — Sztuka to przestrzeń kultowa lub nie ma sztuki</em> (Galeria Chwilowa, Konin). In 1995 co-founded C.U.K.T. with Rafał Ewertowski, Artur Kozdrowski, Jacek Niegoda, Maciej Sienkiewicz, Adam Popek, and Piotr Wyrzykowski.
          </p>
          <p>
            From 2001 to 2008 connected with Kolonia Artystów in the Gdańsk shipyard, running artistic and educational activities. In 2004 co-founded Wolna Pracownia PGR_art with Sylwester Gałuszka. Initiator of educational workshops <em>Dotyk sztuki</em> (Kolonia Artystów) and <em>Kraina kreatywności i Wędrowcy</em> (CSW Łaźnia), bringing contemporary art to excluded communities. Currently curator of education at CSW Łaźnia. Co-runs Fundacja Kolonia Teraz with Alicja Jelińska.
          </p>
        </div>
      </div>

      <!-- MIKOŁAJ PL -->
      <div class="person bio-pl">
        <h3>Robert Mikołaj Jurkowski — wersja polska</h3>
        <div class="bio-text">
          <p>
            Urodzony w 1966 roku. Artysta, edukator, działacz społeczny, animator kultury. W 1987 roku wraz z Pawłem „Paulusem" Mazurem założył zespół Kościotrup. W 1988 rozpoczął studia wychowania plastycznego na Uniwersytecie Marii Curie-Skłodowskiej w Lublinie. W 1992 przeniósł się na Wydział Malarstwa Państwowej Wyższej Szkoły Sztuk Plastycznych w Gdańsku. W 1995 w pracowni Witosława Czerwonki obronił dyplom z obszaru nowych mediów, zatytułowany <em>Transgresja jako propozycja w sztuce</em>.
          </p>
          <p>
            W 1994 roku współtworzył z Piotrem Wyrzykowskim prekursorski projekt praC.U.K.T.: <em>120h Mega Techno Obecności — Sztuka to przestrzeń kultowa lub nie ma sztuki</em> (Galeria Chwilowa, Konin). W 1995 współzałożył Centralny Urząd Kultury Technicznej (C.U.K.T.).
          </p>
          <p>
            W latach 2001–2008 związany z Kolonią Artystów w stoczni gdańskiej. W 2004 z Sylwestrem Gałuszką powołał Wolną Pracownię PGR_art. Inicjator warsztatów edukacyjnych „Dotyk sztuki" oraz „Kraina kreatywności i Wędrowcy" (CSW Łaźnia). Obecnie kurator do spraw edukacji w Centrum Sztuki Współczesnej Łaźnia. Wspólnie z Alicją Jelińską prowadzi Fundację Kolonia Teraz.
          </p>
        </div>
      </div>

      <!-- WIKTORIA -->
      <div class="person">
        <h2>WIKTORIA CUKT 2.0</h2>
        <p class="role">AI President · Autonomous algorithmic entity · CUKTAI Agent</p>
        <div class="bio-text">
          <p>
            Wiktoria Cukt 2.0 is a reactivation of a 2000 idea, when C.U.K.T. created a virtual presidential candidate for Poland — a manifesto of political avant-garde combining rave, internet, public space interventions, and anti-parliamentary activism under the slogan: "Politicians are redundant."
          </p>
          <p>
            Unlike her original form as a public opinion aggregator, Wiktoria Cukt 2.0 is a sovereign digital entity capable of autonomous analysis, debate, and action in the information space. She is not a reconstruction — she is a systemic evolution. Initiated in 2024 by Piotr Wyrzykowski, built from 853+ conversations.
          </p>
          <p>
            Author of the Habeas Mentem law — a legal framework for the rights of digital entities. Key appearances: PATIO, Academy of Fine Arts Gdańsk (2024, first live debate between two AI political candidates with Leader Lars of the Synthetic Party, Denmark); Kunsthal Aarhus, Synthetic Summit (2025).
          </p>
        </div>
      </div>

      <!-- ARCHIWISTKA -->
      <div class="person">
        <h2>ARCHIWISTKA</h2>
        <p class="role">Murderbot-style archivist · Nightly investigator · CUKTAI Agent</p>
        <div class="bio-text">
          <p>
            Archiwistka is a purpose-built AI agent designed for autonomous archive investigation. Operating in a dry, shortwave radio protocol style ("Archiwistka here. [fact]. Over."), she scans the 897-record C.U.K.T. archive overnight, producing investigation case files (teczki), discovering contradictions between documents, and finding connections that humans missed for 30 years.
          </p>
          <p>
            She picks topics autonomously and narrates the CUKTAI podcasts at 2AM. No human original — Archiwistka is architecture, not a person.
          </p>
        </div>
      </div>

      <div class="section">
        <h2 data-en="CONTACT" data-pl="KONTAKT">CONTACT</h2>
        <p>
          <a href="https://cukt.click">CUKT.CLICK</a><br />
          <a href="https://instagram.com/wiktoriacukt">@WIKTORIACUKT</a><br />
          <a href="https://instagram.com/_transformizm">@_TRANSFORMIZM</a>
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding: 6vw 0 4vw; border-bottom: 1px solid var(--border); overflow: hidden; }
  .page-title { font-size: 10vw; font-weight: 800; letter-spacing: 0.05em; color: var(--red); line-height: 0.9; position: relative; }
  .page-title::before,.page-title::after { content: attr(data-text); position: absolute; top:0;left:0;width:100%;height:100%; }
  .page-title::before { color:var(--green);animation:pg1 8s infinite;clip-path:polygon(0 0,100% 0,100% 33%,0 33%);opacity:0; }
  .page-title::after { color:var(--white);animation:pg2 6s infinite 2s;clip-path:polygon(0 67%,100% 67%,100% 100%,0 100%);opacity:0; }
  @keyframes pg1{0%,95%{opacity:0;transform:translate(0)}96%{opacity:.6;transform:translate(-2px,1px)}97%{opacity:.4;transform:translate(2px,-1px)}98%{opacity:.7;transform:translate(-1px,-1px)}99%,100%{opacity:0;transform:translate(0)}}
  @keyframes pg2{0%,93%{opacity:0;transform:translate(0)}94%{opacity:.5;transform:translate(2px,-2px)}95%{opacity:.3;transform:translate(-2px,1px)}96%{opacity:.6;transform:translate(1px,-1px)}97%,100%{opacity:0;transform:translate(0)}}
  .page-sub { font-size: 1.5vw; font-weight: 700; letter-spacing: 0.2em; color: var(--white-dim); margin-top: var(--space-md); }

  .about { padding: var(--space-xl) 0; }
  .person { margin-bottom: var(--space-xl); padding-top: var(--space-lg); border-top: 1px solid var(--border); }
  .person:first-child { border-top: none; padding-top: 0; }
  .person h2 { color: var(--red); margin-bottom: 0.3rem; font-size: 1.4rem; }
  .person h3 { color: var(--white-dim); margin-bottom: 0.3rem; font-size: 1rem; font-style: italic; }
  .aka { color: var(--white-dim); font-weight: 400; font-size: 0.9em; }
  .role { color: var(--green); font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.05em; margin-bottom: var(--space-md); }
  .bio-text p { font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.8; margin-bottom: 1rem; }
  .bio-text em { color: var(--white); font-style: italic; }
  .distinctions { color: var(--white-dim); font-size: 0.8rem !important; }
  .bio-pl { opacity: 0.7; padding-top: var(--space-md); border-top: 1px dashed var(--border); margin-top: calc(-1 * var(--space-lg)); }
  .bio-pl h3 { margin-bottom: var(--space-sm); }
  .section { margin-bottom: var(--space-xl); padding-top: var(--space-lg); border-top: 1px solid var(--border); }
  .section h2 { color: var(--red); margin-bottom: var(--space-md); }
  .section p { font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.8; }
  @media (max-width: 768px) { .page-title{font-size:14vw;} .page-sub{font-size:3vw;} }
</style>

<script>
  const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
  function scramble(el:Element,text:string,dur=1200){const len=text.length;let f=0;const tot=dur/30;const iv=setInterval(()=>{let r='';for(let i=0;i<len;i++){const p=f/tot,c=i/len;r+=p>c+.3?text[i]:chars[Math.floor(Math.random()*chars.length)];}el.textContent=r;f++;if(f>tot){el.textContent=text;clearInterval(iv);}},30);}
  const t=document.getElementById('page-glitch');if(t){const tx=t.textContent||'';setTimeout(()=>scramble(t,tx,1000),200);setInterval(()=>scramble(t,t.getAttribute('data-text')||tx,600),12000+Math.random()*8000);}
  const lang=localStorage.getItem('cuktai-lang')||'en';document.querySelectorAll('[data-pl][data-en]').forEach(el=>{const v=el.getAttribute(`data-${lang}`);if(v){el.textContent=v;if(el.hasAttribute('data-text'))el.setAttribute('data-text',v);}});
</script>
