---
import Base from '../layouts/Base.astro';
---

<Base title="Piotr Wyrzykowski — Artist, Researcher" description="Piotr Wyrzykowski (Peter Style) — artist, researcher, lecturer. Co-founder of C.U.K.T. (1995). Head of Dept of Artistic Specializations, ASP Gdańsk.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title" id="page-glitch" data-text="ABOUT" data-en="ABOUT" data-pl="INFO">ABOUT</h1>
      <p class="page-sub">PIOTR WYRZYKOWSKI / PETER STYLE</p>
    </div>
  </section>

  <section class="about">
    <div class="container content">
      <div class="bio">
        <p>
          Artist, researcher, lecturer. Co-founder of C.U.K.T. (Centralny Urzad Kultury Technicznej, 1995).
          Creator of Transformism — an artistic theory connecting body, technology, and identity.
        </p>
        <p>
          Head of Department of Artistic Specializations, Academy of Fine Arts in Gdansk.
          Lecturer in New Media and Video Narrative, Polish-Japanese Academy of Information Technology.
        </p>
      </div>

      <div class="section">
        <h2>CUKTAI</h2>
        <p>
          Autonomous Bureau of Technical Culture — an AI system transforming
          the C.U.K.T. archive into a multi-voice agent network. Year-long conference, 2026.
        </p>
        <p>
          <span class="label">MOTTO:</span> My memory in your head<br />
          <span class="label">PHASE:</span> 4.6 — Subconsciousness (beta)<br />
          <span class="label">AGENTS:</span> Wiktoria Cukt 2.0, Ewa Virus Adam, Peter Twin, Archiwistka
        </p>
      </div>

      <div class="section">
        <h2 data-en="CONTACT" data-pl="KONTAKT">CONTACT</h2>
        <p>
          <a href="https://instagram.com/wiktoriacukt">@WIKTORIACUKT</a><br />
          <a href="https://instagram.com/_transformizm">@_TRANSFORMIZM</a>
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding: 6vw 0 4vw; border-bottom: 1px solid var(--border); overflow: hidden; }
  .page-title { font-size: 10vw; font-weight: 800; letter-spacing: 0.05em; color: var(--red); line-height: 0.9; position: relative; }
  .page-title::before,.page-title::after { content: attr(data-text); position: absolute; top:0;left:0;width:100%;height:100%; }
  .page-title::before { color:var(--green);animation:pg1 8s infinite;clip-path:polygon(0 0,100% 0,100% 33%,0 33%);opacity:0; }
  .page-title::after { color:var(--white);animation:pg2 6s infinite 2s;clip-path:polygon(0 67%,100% 67%,100% 100%,0 100%);opacity:0; }
  @keyframes pg1{0%,95%{opacity:0;transform:translate(0)}96%{opacity:.6;transform:translate(-2px,1px)}97%{opacity:.4;transform:translate(2px,-1px)}98%{opacity:.7;transform:translate(-1px,-1px)}99%,100%{opacity:0;transform:translate(0)}}
  @keyframes pg2{0%,93%{opacity:0;transform:translate(0)}94%{opacity:.5;transform:translate(2px,-2px)}95%{opacity:.3;transform:translate(-2px,1px)}96%{opacity:.6;transform:translate(1px,-1px)}97%,100%{opacity:0;transform:translate(0)}}
  .page-sub { font-size: 1.5vw; font-weight: 700; letter-spacing: 0.2em; color: var(--white-dim); margin-top: var(--space-md); }

  .about { padding: var(--space-xl) 0; }
  .bio { margin-bottom: var(--space-xl); }
  .bio p { font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.8; }
  .section { margin-bottom: var(--space-xl); padding-top: var(--space-lg); border-top: 1px solid var(--border); }
  .section h2 { color: var(--red); margin-bottom: var(--space-md); }
  .section p { font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.8; }
  .label { color: var(--white-dim); font-size: 0.8rem; }
  @media (max-width: 768px) { .page-title{font-size:14vw;} .page-sub{font-size:3vw;} }
</style>

<script>
  const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
  function scramble(el:Element,text:string,dur=1200){const len=text.length;let f=0;const tot=dur/30;const iv=setInterval(()=>{let r='';for(let i=0;i<len;i++){const p=f/tot,c=i/len;r+=p>c+.3?text[i]:chars[Math.floor(Math.random()*chars.length)];}el.textContent=r;f++;if(f>tot){el.textContent=text;clearInterval(iv);}},30);}
  const t=document.getElementById('page-glitch');if(t){const tx=t.textContent||'';setTimeout(()=>scramble(t,tx,1000),200);setInterval(()=>scramble(t,t.getAttribute('data-text')||tx,600),12000+Math.random()*8000);}
  const lang=localStorage.getItem('cuktai-lang')||'en';document.querySelectorAll('[data-pl][data-en]').forEach(el=>{const v=el.getAttribute(`data-${lang}`);if(v){el.textContent=v;if(el.hasAttribute('data-text'))el.setAttribute('data-text',v);}});
</script>
