---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('cukt');
const sorted = projects.sort((a, b) => (a.data.number ?? 99) - (b.data.number ?? 99));
---

<Base title="CUKT ARCHIVE" description="23 projects by Centralny Urzad Kultury Technicznej (1995-2001+)">
  <section class="archive-header">
    <div class="container">
      <h1 data-en="CUKT ARCHIVE" data-pl="ARCHIWUM CUKT">CUKT ARCHIVE</h1>
      <p class="subtitle" data-en="23 PROJECTS / 1995–2001+" data-pl="23 PROJEKTY / 1995–2001+">23 PROJECTS / 1995–2001+</p>
      <p class="dim">WYRZYKOWSKI / JURKOWSKI / POPEK</p>
    </div>
  </section>

  <section class="archive-list">
    <div class="container">
      <div class="grid-projects">
        {sorted.map((project, i) => (
          <a href={`/archive/${project.id}`} class="project-card">
            <span class="card-number">{String(i + 1).padStart(2, '0')}</span>
            <h3>{project.data.title}</h3>
            <p class="meta">{project.data.date}</p>
            {project.data.authors && <p class="meta authors">{project.data.authors}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .archive-header {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .archive-header h1 {
    color: var(--red);
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    color: var(--white);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-xs);
  }

  .dim {
    color: var(--white-dim);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }

  .archive-list {
    padding: var(--space-xl) 0;
  }

  .card-number {
    color: var(--red-dim);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .project-card h3 {
    color: var(--white);
  }

  .authors {
    color: var(--white-dim);
  }
</style>

<script>
  // Apply saved language on load
  const lang = localStorage.getItem('cuktai-lang') || 'en';
  document.querySelectorAll('[data-pl][data-en]').forEach(el => {
    const text = el.getAttribute(`data-${lang}`);
    if (text) el.textContent = text;
  });
</script>
