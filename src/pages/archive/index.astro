---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('cukt');
const sorted = projects.sort((a, b) => (a.data.number ?? 99) - (b.data.number ?? 99));
---

<Base title="ARCHIWUM CUKT" description="23 projekty Centralnego Urzadu Kultury Technicznej (1992-2001+)">
  <section class="archive-header">
    <div class="container">
      <h1>ARCHIWUM CUKT</h1>
      <p class="subtitle">23 PROJEKTY / 1992–2001+</p>
      <p class="dim">WYRZYKOWSKI / JURKOWSKI / POPEK</p>
    </div>
  </section>

  <section class="archive-list">
    <div class="container">
      <div class="grid-projects">
        {sorted.map((project) => (
          <a href={`/archive/${project.id}`} class="project-card">
            <span class="card-number">#{project.data.number ?? '?'}</span>
            <h3>{project.data.title}</h3>
            <p class="meta">{project.data.date}</p>
            {project.data.authors && <p class="meta">{project.data.authors}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .archive-header {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .archive-header h1 {
    color: var(--red);
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    color: var(--white);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-xs);
  }

  .dim {
    color: var(--white-dim);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }

  .archive-list {
    padding: var(--space-xl) 0;
  }

  .card-number {
    color: var(--red-dim);
    font-size: 0.75rem;
    display: block;
    margin-bottom: var(--space-xs);
  }
</style>
