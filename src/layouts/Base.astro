---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CUKTAI — Autonomous Bureau of Technical Culture. Multi-voice AI system built on the C.U.K.T. archive (1995-2001).' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <title>{title} | CUKTAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="canonical" href={canonicalURL.href} />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | CUKTAI`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CUKTAI" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:locale:alternate" content="pl_PL" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | CUKTAI`} />
  <meta name="twitter:description" content={description} />
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">CUKTAI</a>
      <div class="nav-links">
        <a href="/archive" data-pl="ARCHIWUM" data-en="ARCHIVE">ARCHIVE</a>
        <a href="/personal" data-pl="PROJEKTY" data-en="PROJECTS">PROJECTS</a>
        <a href="/tags" data-pl="TAGI" data-en="TAGS">TAGS</a>
        <a href="/archiwistka">ARCHIWISTKA</a>
        <a href="/podcasts" data-pl="PODCASTY" data-en="PODCASTS">PODCASTS</a>
        <a href="/live">LIVE</a>
        <a href="/about" data-pl="INFO" data-en="ABOUT">ABOUT</a>
      </div>
      <div class="nav-right">
        <button class="lang-switch" id="lang-toggle" aria-label="Switch language">
          <span class="lang-opt active" data-lang="en">EN</span>
          <span class="lang-sep">/</span>
          <span class="lang-opt" data-lang="pl">PL</span>
        </button>
        <button class="nav-toggle" aria-label="Menu">///</button>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-inner">
        <div>
          <span class="footer-title">CUKTAI</span><br />
          <span class="footer-dim">AUTONOMOUS BUREAU OF TECHNICAL CULTURE</span><br />
          <span class="footer-dim">WYRZYKOWSKI / JURKOWSKI / POPEK</span>
        </div>
        <div class="footer-right">
          <a href="https://instagram.com/wiktoriacukt">@WIKTORIACUKT</a><br />
          <a href="https://instagram.com/_transformizm">@_TRANSFORMIZM</a>
        </div>
      </div>
    </div>
  </footer>

  <style is:global>
    @import '../styles/global.css';

    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: var(--space-sm) 0;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-size: 1.25rem;
      font-weight: 800;
      letter-spacing: 3px;
      color: var(--white) !important;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: var(--space-lg);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 2px;
    }

    .nav-links a {
      color: var(--white-dim);
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--white);
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: var(--space-md);
    }

    .lang-switch {
      background: none;
      border: 1px solid var(--border);
      color: var(--white-dim);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      cursor: pointer;
      padding: 3px 8px;
      display: flex;
      align-items: center;
      gap: 2px;
    }

    .lang-opt { transition: color 0.2s; }
    .lang-opt.active { color: var(--white); }
    .lang-sep { color: var(--border); }

    .lang-switch:hover {
      border-color: var(--white-dim);
    }

    .nav-toggle {
      display: none;
      background: none;
      border: 1px solid var(--border);
      color: var(--red);
      font-family: var(--font-mono);
      font-size: 1.2rem;
      cursor: pointer;
      padding: 4px 8px;
    }

    .footer {
      border-top: 1px solid var(--border);
      padding: var(--space-xl) 0;
      margin-top: var(--space-2xl);
      font-size: 0.8rem;
      letter-spacing: 1px;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .footer-title {
      color: var(--red);
      font-weight: 800;
      font-size: 1rem;
      letter-spacing: 3px;
    }

    .footer-dim {
      color: var(--white-dim);
      font-size: 0.75rem;
    }

    .footer-right {
      text-align: right;
      text-transform: uppercase;
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-toggle { display: block; }
      .footer-inner { flex-direction: column; gap: var(--space-md); }
      .footer-right { text-align: left; }
    }
  </style>

  <script>
    // Mobile menu toggle
    const toggle = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    toggle?.addEventListener('click', () => {
      const expanded = links?.style.display === 'flex';
      if (links) {
        links.style.display = expanded ? 'none' : 'flex';
        links.style.flexDirection = 'column';
        links.style.position = 'absolute';
        links.style.top = '100%';
        links.style.left = '0';
        links.style.right = '0';
        links.style.background = 'rgba(10,10,10,0.98)';
        links.style.padding = '1rem 2rem';
      }
    });

    // Language switch
    const langToggle = document.getElementById('lang-toggle');
    const langOpts = document.querySelectorAll('.lang-opt');

    function setLang(lang: string) {
      langOpts.forEach(opt => {
        opt.classList.toggle('active', opt.getAttribute('data-lang') === lang);
      });

      // Update nav links
      document.querySelectorAll('[data-pl][data-en]').forEach(el => {
        const text = el.getAttribute(`data-${lang}`);
        if (text) el.textContent = text;
      });

      // Update translatable content
      document.querySelectorAll('[data-pl][data-en]:not(.nav-links a)').forEach(el => {
        const text = el.getAttribute(`data-${lang}`);
        if (text) el.textContent = text;
      });

      localStorage.setItem('cuktai-lang', lang);
    }

    langToggle?.addEventListener('click', () => {
      const current = localStorage.getItem('cuktai-lang') || 'en';
      setLang(current === 'en' ? 'pl' : 'en');
    });

    // Restore saved lang
    const saved = localStorage.getItem('cuktai-lang');
    if (saved) setLang(saved);
  </script>
</body>
</html>
