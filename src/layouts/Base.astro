---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CUKTAI — Autonomiczny Urząd Kultury Technicznej' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | CUKTAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">CUKTAI</a>
      <div class="nav-links">
        <a href="/archive">ARCHIWUM</a>
        <a href="/personal">PROJEKTY</a>
        <a href="/tags">TAGI</a>
        <a href="/live">LIVE</a>
        <a href="/about">INFO</a>
      </div>
      <button class="nav-toggle" aria-label="Menu">///</button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-inner">
        <div>
          <span class="footer-title">CUKTAI</span><br />
          <span class="footer-dim">CENTRALNY URZAD KULTURY TECHNICZNEJ</span><br />
          <span class="footer-dim">WYRZYKOWSKI / JURKOWSKI / POPEK</span>
        </div>
        <div class="footer-right">
          <a href="https://instagram.com/wiktoriacukt">@WIKTORIACUKT</a><br />
          <a href="https://instagram.com/_transformizm">@_TRANSFORMIZM</a>
        </div>
      </div>
    </div>
  </footer>

  <style>
    @import '../styles/global.css';

    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: var(--space-sm) 0;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-size: 1.25rem;
      font-weight: 800;
      letter-spacing: 3px;
      color: var(--red) !important;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: var(--space-lg);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 2px;
    }

    .nav-links a {
      color: var(--white-dim);
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--white);
    }

    .nav-toggle {
      display: none;
      background: none;
      border: 1px solid var(--border);
      color: var(--red);
      font-family: var(--font-mono);
      font-size: 1.2rem;
      cursor: pointer;
      padding: 4px 8px;
    }

    .footer {
      border-top: 1px solid var(--border);
      padding: var(--space-xl) 0;
      margin-top: var(--space-2xl);
      font-size: 0.8rem;
      letter-spacing: 1px;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .footer-title {
      color: var(--red);
      font-weight: 800;
      font-size: 1rem;
      letter-spacing: 3px;
    }

    .footer-dim {
      color: var(--white-dim);
      font-size: 0.75rem;
    }

    .footer-right {
      text-align: right;
      text-transform: uppercase;
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-toggle { display: block; }
      .footer-inner { flex-direction: column; gap: var(--space-md); }
      .footer-right { text-align: left; }
    }
  </style>

  <script>
    const toggle = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    toggle?.addEventListener('click', () => {
      const expanded = links?.style.display === 'flex';
      if (links) {
        links.style.display = expanded ? 'none' : 'flex';
        links.style.flexDirection = 'column';
        links.style.position = 'absolute';
        links.style.top = '100%';
        links.style.left = '0';
        links.style.right = '0';
        links.style.background = 'rgba(10,10,10,0.98)';
        links.style.padding = '1rem 2rem';
      }
    });
  </script>
</body>
</html>
